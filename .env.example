# AlphaForge — Environment Variables
# Copy this file to .env and fill in your keys

# Finnhub (free tier: 60 calls/min) — https://finnhub.io
FINNHUB_API_KEY=your_finnhub_key_here

# Anthropic (AI Research Assistant) — https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_key_here

# Alpha Vantage (optional backup) — https://www.alphavantage.co
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# The Odds API (80+ bookmakers, real-time sports odds) — https://the-odds-api.com
# Free tier: 500 requests/month. Dashboard caches 30 min to preserve quota.
# 1win does not provide a public API; The Odds API covers Pinnacle, Bet365, etc.
ODDS_API_KEY=your_odds_api_key_here

# football-data.org (historical match results for Poisson model calibration)
# Free: unlimited requests, 10/min. Register at https://www.football-data.org/client/register
# Covers: Premier League, La Liga, Bundesliga, Serie A, Ligue 1, Champions League.
FOOTBALL_DATA_KEY=your_football_data_key_here

# App settings
ALPHAFORGE_ENV=development
CACHE_TTL_SECONDS=300
